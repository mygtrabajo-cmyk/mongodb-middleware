# ================================================================
# MYG TELECOM — Variables de Entorno (Backend / Render)
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env al repositorio.
# ================================================================

# ── Requeridas (sin estas el servidor no arranca) ────────────────
JWT_SECRET=cambiar-por-secreto-aleatorio-256bits
NEBULA_AGENT_SECRET=cambiar-por-secreto-nebula
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/iqu_telecom

# ── Servidor ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://mygtelecom.netlify.app

# ── APIs externas (opcionales) ────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
GOOGLE_SHEETS_KEY=

# ── Google Sheets IDs (mover de config.js a aquí) ─────────────────
SHEET_ID_RH=
SHEET_ID_CORREOS=
SHEET_ID_EQUIPOS_IQU=
SHEET_ID_PDV_DETALLES=
SHEET_ID_CORREOS_DETALLADOS=
SHEET_ID_ACTIVOS=
SHEET_ID_REPOSICIONES=
SHEET_ID_TICKETS_DASHBOARD=
SHEET_ID_TICKETS_CONTEO=
SHEET_ID_RH_POC=
SHEET_ID_RH_HISTORICO=
SHEET_ID_SEGUIMIENTO_ALTAS=
SHEET_ID_HEADCOUNT=

# ── Observabilidad ────────────────────────────────────────────────
# Obtener DSN en sentry.io → Projects → tu-proyecto → Settings → Client Keys
SENTRY_DSN=
LOG_LEVEL=info

# ── Reportes semanales (opt-in explícito) ─────────────────────────
WEEKLY_REPORT_ENABLED=false
WEEKLY_REPORT_RECIPIENTS=usuario@mygtelecom.mx
WEEKLY_REPORT_DAY=1
WEEKLY_REPORT_HOUR=8
WEEKLY_REPORT_TZ_OFFSET=-6
SMTP_HOST=smtp.tu-proveedor.com
SMTP_USER=correo@mygtelecom.mx
SMTP_PASS=
SMTP_PORT=587

# ── CSP (Helmet en server.js) ─────────────────────────────────────
CSP_REPORT_ONLY=false
CLOUDFLARE_WORKER_URL=https://dashboard-myg-api.mygtrabajo.workers.dev
